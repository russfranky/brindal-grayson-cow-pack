{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "bgcow:brindal_cow",
      "materials": {
        "default": "cow"
      },
      "textures": {
        "default": "textures/entity/brindal_cow"
      },
      "geometry": {
        "default": "geometry.cow.v2"
      },
      "animations": {
        "setup": "animation.cow.setup",
        "walk": "animation.quadruped.walk",
        "look_at_target": "animation.common.look_at_target",
        "baby_transform": "animation.cow.baby_transform"
      },
      "scripts": {
        "animate": [
          "setup",
          { "walk": "query.modified_move_speed" },
          "look_at_target"
        ],
        "scale": "query.is_baby ? 2.0 : 1.0"
      },
      "render_controllers": ["controller.render.cow"],
      "spawn_egg": {
        "base_color": "#8B5A2B",
        "overlay_color": "#FFFFFF"
      }
    }
  }
}
