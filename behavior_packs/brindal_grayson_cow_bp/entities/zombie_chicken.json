{
  "format_version": "1.21.0",
  "minecraft:entity": {
    "description": {
      "identifier": "bgcow:zombie_chicken",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "bgcow:baby": {
        "minecraft:is_baby": {},
        "minecraft:scale": { "value": 0.5 },
        "minecraft:ageable": {
          "duration": 1200,
          "feed_items": [
            "wheat_seeds",
            "beetroot_seeds",
            "melon_seeds",
            "pumpkin_seeds"
          ],
          "grow_up": {
            "event": "bgcow:ageable_grow_up",
            "target": "self"
          }
        },
        "minecraft:behavior.follow_parent": {
          "priority": 5,
          "speed_multiplier": 1.1
        }
      },
      "bgcow:adult": {
        "minecraft:experience_reward": {
          "on_bred": "Math.Random(1,7)",
          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:loot": {
          "table": "loot_tables/entities/chicken.json"
        },
        "minecraft:breedable": {
          "require_tame": false,
          "breed_items": [
            "wheat_seeds",
            "beetroot_seeds",
            "melon_seeds",
            "pumpkin_seeds"
          ],
          "breeds_with": {
            "bgcow:zombie_chicken": {},
            "bgcow:chaos_chicken": {}
          }
        },
        "minecraft:behavior.breed": {
          "priority": 3,
          "speed_multiplier": 1.0
        },
        "minecraft:spawn_entity": {
          "entities": [
            {
              "min_wait_time": 300,
              "max_wait_time": 600,
              "spawn_sound": "plop",
              "spawn_item": "egg"
            }
          ]
        }
      },
      "bgcow:size_peep": { "minecraft:scale": { "value": 0.35 } },
      "bgcow:size_small": { "minecraft:scale": { "value": 0.65 } },
      "bgcow:size_normal": { "minecraft:scale": { "value": 1.0 } },
      "bgcow:size_big": { "minecraft:scale": { "value": 1.5 } },
      "bgcow:size_giant": { "minecraft:scale": { "value": 2.2 } }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["chicken", "zombie_chicken", "mob"]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:nameable": {
        "always_show": true
      },
      "minecraft:health": { "value": 6, "max": 6 },
      "minecraft:movement": { "value": 0.28 },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:collision_box": { "width": 0.6, "height": 0.8 },
      "minecraft:physics": {},
      "minecraft:pushable": {},
      "minecraft:behavior.float": { "priority": 0 },
      "minecraft:behavior.panic": { "priority": 1, "speed_multiplier": 1.5 },
      "minecraft:behavior.tempt": {
        "priority": 4,
        "speed_multiplier": 1.0,
        "items": [
          "wheat_seeds",
          "beetroot_seeds",
          "melon_seeds",
          "pumpkin_seeds"
        ]
      },
      "minecraft:behavior.random_stroll": { "priority": 6, "speed_multiplier": 1.0 },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 8.0,
        "probability": 0.04
      },
      "minecraft:behavior.random_look_around": { "priority": 8 }
    },
    "events": {
      "minecraft:entity_spawned": {
        "randomize": [
          { "weight": 5, "add": { "component_groups": ["bgcow:baby"] } },
          { "weight": 95, "trigger": "bgcow:spawn_adult" }
        ]
      },
      "minecraft:entity_born": {
        "add": { "component_groups": ["bgcow:baby"] }
      },
      "bgcow:spawn_adult": {
        "add": { "component_groups": ["bgcow:adult"] },
        "trigger": "bgcow:random_size"
      },
      "bgcow:ageable_grow_up": {
        "remove": { "component_groups": ["bgcow:baby"] },
        "add": { "component_groups": ["bgcow:adult"] },
        "trigger": "bgcow:random_size"
      },
      "bgcow:random_size": {
        "randomize": [
          { "weight": 10, "add": { "component_groups": ["bgcow:size_peep"] } },
          { "weight": 20, "add": { "component_groups": ["bgcow:size_small"] } },
          { "weight": 35, "add": { "component_groups": ["bgcow:size_normal"] } },
          { "weight": 20, "add": { "component_groups": ["bgcow:size_big"] } },
          { "weight": 15, "add": { "component_groups": ["bgcow:size_giant"] } }
        ]
      }
    }
  }
}
